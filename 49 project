import tkinter as tk
from tkinter import messagebox
def run_command():
    command = command_entry.get().lower()
    if command == "":
        messagebox.showwarning("Warning", "Enter a command!")
        return
    if command == "hello":
        output_label.config(text="Jarvis: Hello Kamran!")
    elif command == "time":
        import time
        output_label.config(text=f"Jarvis: {time.strftime('%H:%M:%S')}")
    elif command == "date":
        import datetime
        output_label.config(
            text=f"Jarvis: {datetime.date.today()}"
        )
    elif command == "open google":
        import webbrowser
        webbrowser.open("https://www.google.com")
        output_label.config(text="Jarvis: Opening Google...")
    elif command == "open youtube":
        import webbrowser
        webbrowser.open("https://www.youtube.com")
        output_label.config(text="Jarvis: Opening YouTube...")
    elif command == "clear":
        output_label.config(text="Jarvis Ready")
        command_entry.delete(0, tk.END)
    else:
        output_label.config(
            text="Jarvis: Command not recognized."
        )
root = tk.Tk()
root.title("Jarvis Command Dashboard")
root.geometry("500x300")
title_label = tk.Label(
    root,
    text="JARVIS COMMAND DASHBOARD",
    font=("Arial", 16)
)
title_label.pack(pady=10)
command_entry = tk.Entry(
    root,
    width=40,
    font=("Arial", 12)
)
command_entry.pack(pady=10)
run_button = tk.Button(
    root,
    text="Run Command",
    command=run_command
)
run_button.pack(pady=5)
output_label = tk.Label(
    root,
    text="Jarvis Ready",
    font=("Arial", 12)
)
output_label.pack(pady=20)
root.mainloop()